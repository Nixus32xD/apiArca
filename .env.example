APP_NAME="API ARCA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://apiarca.example.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# En Docker, DB_HOST debe ser el nombre del service/host de base de datos,
# no 127.0.0.1, salvo que la DB corra dentro del mismo contenedor.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=apiarca
DB_USERNAME=apiarca
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

###############################################################################
# Fiscal API interna
###############################################################################

# Tokens que puede usar el SaaS para llamar /api/fiscal/*.
# Se aceptan valores planos separados por coma o sha256:<hash>.
FISCAL_API_TOKENS=change-me-long-random-token

# Admin HTML en /api/admin/. En production debe quedar protegido por token.
FISCAL_ADMIN_ENABLED=true
FISCAL_ADMIN_TOKEN=change-me-admin-token

###############################################################################
# ARCA / AFIP - OpenSSL
###############################################################################

# IMPORTANTE para Docker + OpenSSL 3:
# OPENSSL_CONF debe existir dentro del contenedor y estar seteado antes de
# iniciar PHP-FPM/worker. El repo trae openssl.cnf en la raiz.
OPENSSL_CONF=/var/www/html/openssl.cnf

# Config usada por operaciones OpenSSL internas de la app: CSR y firma WSAA.
FISCAL_OPENSSL_CONF=/var/www/html/openssl.cnf
FISCAL_OPENSSL_PRIVATE_KEY_BITS=2048

###############################################################################
# ARCA / AFIP - WSAA y WSFEv1
###############################################################################

FISCAL_STRICT_ENDPOINT_ENV_CHECK=true
FISCAL_WSAA_SERVICE=wsfe
FISCAL_WSAA_TICKET_TTL_MINUTES=720
FISCAL_WSAA_RENEW_WITHIN_MINUTES=30

FISCAL_WSAA_TESTING_URL=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
FISCAL_WSAA_PRODUCTION_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms

FISCAL_WSFEV1_TESTING_URL=https://wswhomo.afip.gov.ar/wsfev1/service.asmx
FISCAL_WSFEV1_PRODUCTION_URL=https://servicios1.afip.gov.ar/wsfev1/service.asmx
FISCAL_WSFEV1_TESTING_WSDL=https://wswhomo.afip.gov.ar/wsfev1/service.asmx?WSDL
FISCAL_WSFEV1_PRODUCTION_WSDL=https://servicios1.afip.gov.ar/wsfev1/service.asmx?WSDL

###############################################################################
# SOAP timeouts / retries
###############################################################################

FISCAL_SOAP_TIMEOUT=30
FISCAL_SOAP_CONNECT_TIMEOUT=10
FISCAL_SOAP_RETRY_TIMES=2
FISCAL_SOAP_RETRY_SLEEP_MS=1000

FISCAL_SOAP_WSAA_TIMEOUT=25
FISCAL_SOAP_WSAA_CONNECT_TIMEOUT=10
FISCAL_SOAP_WSAA_RETRY_TIMES=2
FISCAL_SOAP_WSAA_RETRY_SLEEP_MS=1000

FISCAL_SOAP_WSFE_AUTHORIZE_TIMEOUT=35
FISCAL_SOAP_WSFE_AUTHORIZE_CONNECT_TIMEOUT=12
FISCAL_SOAP_WSFE_AUTHORIZE_RETRY_TIMES=2
FISCAL_SOAP_WSFE_AUTHORIZE_RETRY_SLEEP_MS=1200

FISCAL_SOAP_WSFE_LAST_AUTH_TIMEOUT=20
FISCAL_SOAP_WSFE_LAST_AUTH_CONNECT_TIMEOUT=10
FISCAL_SOAP_WSFE_LAST_AUTH_RETRY_TIMES=2
FISCAL_SOAP_WSFE_LAST_AUTH_RETRY_SLEEP_MS=800

FISCAL_SOAP_WSFE_CONSULT_TIMEOUT=20
FISCAL_SOAP_WSFE_CONSULT_CONNECT_TIMEOUT=10
FISCAL_SOAP_WSFE_CONSULT_RETRY_TIMES=2
FISCAL_SOAP_WSFE_CONSULT_RETRY_SLEEP_MS=800

FISCAL_SOAP_WSFE_CATALOG_TIMEOUT=15
FISCAL_SOAP_WSFE_CATALOG_CONNECT_TIMEOUT=8
FISCAL_SOAP_WSFE_CATALOG_RETRY_TIMES=1
FISCAL_SOAP_WSFE_CATALOG_RETRY_SLEEP_MS=500

FISCAL_SOAP_WSFE_DUMMY_TIMEOUT=10
FISCAL_SOAP_WSFE_DUMMY_CONNECT_TIMEOUT=5
FISCAL_SOAP_WSFE_DUMMY_RETRY_TIMES=1
FISCAL_SOAP_WSFE_DUMMY_RETRY_SLEEP_MS=500

###############################################################################
# Defaults fiscales
###############################################################################

FISCAL_DEFAULT_CONCEPT=1
FISCAL_DEFAULT_CURRENCY=PES
FISCAL_DEFAULT_CURRENCY_RATE=1
FISCAL_CONSUMER_FINAL_DOC_TYPE=99
FISCAL_CONSUMER_FINAL_DOC_NUMBER=0
FISCAL_CONSUMER_FINAL_TAX_CONDITION_ID=5
FISCAL_DEFAULT_IVA_ID=5
FISCAL_LOG_MAX_PAYLOAD_CHARS=8000
